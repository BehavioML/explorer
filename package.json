{
  "name": "@behavioml/explorer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Initial scaffold for the BehavioML Model Explorer.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "node --import tsx --test tests/*.test.mjs tests/*.test.ts",
    "test:smoke": "playwright test",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@behavioml/generator": "github:BehavioML/generator#main",
    "@behavioml/validator": "github:BehavioML/validator#main",
    "fflate": "^0.8.3",
    "mermaid": "^11.15.0",
    "path-browserify": "^1.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
